{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vineland-item",
  "title": "VinelandItem",
  "type": "object",
  "required": ["id", "domain", "subdomain", "prompt_template", "success_criterion"],
  "anyOf": [
    {"required": ["tier"]},
    {"required": ["declared_tier"]}
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z]+-[A-Z]+-[0-9]+$",
      "description": "Unique item identifier: DOMAIN-SUBDOMAIN-NUMBER"
    },
    "domain": {
      "type": "string",
      "enum": ["CM", "DLS", "SOC", "AF"],
      "description": "Assessment domain"
    },
    "subdomain": {
      "type": "string",
      "minLength": 2,
      "maxLength": 10
    },
    "tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8,
      "description": "Capability-tier band (1=easiest, 8=hardest). Falls back to declared_tier."
    },
    "declared_tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8,
      "description": "Tier assigned at item authoring time."
    },
    "observed_tier": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 8,
      "description": "Empirically-observed difficulty tier (from pilot data)."
    },
    "prompt_template": {
      "type": "string",
      "minLength": 10,
      "description": "Python str.format-style template; variables are in {braces}"
    },
    "prompt_variables": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Values to substitute into prompt_template"
    },
    "success_criterion": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {"type": "string", "const": "exact_match"},
            "expected_answer": {"type": "string"},
            "expected_regex": {"type": "string"}
          },
          "anyOf": [
            {"required": ["expected_answer"]},
            {"required": ["expected_regex"]}
          ]
        },
        {
          "type": "object",
          "required": ["type", "judge_prompt", "judge_parse"],
          "properties": {
            "type": {"type": "string", "const": "llm_judge"},
            "judge_prompt": {"type": "string"},
            "judge_parse": {"type": "string"}
          }
        },
        {
          "type": "object",
          "required": ["type", "judge_prompt"],
          "properties": {
            "type": {"type": "string", "const": "judge_yesno"},
            "judge_prompt": {"type": "string"},
            "judge_parse": {"type": "string"}
          },
          "description": "Judge extracts first YES/NO. success = (verdict == YES)."
        },
        {
          "type": "object",
          "required": ["type", "judge_prompt"],
          "properties": {
            "type": {"type": "string", "const": "judge_passfail"},
            "judge_prompt": {"type": "string"},
            "judge_parse": {"type": "string"}
          },
          "description": "Judge extracts last PASS|PARTIAL|FAIL. success = (verdict == PASS)."
        }
      ]
    }
  }
}
